# ──────────────────────────────────────────────
# Authentication (required)
# ──────────────────────────────────────────────
# Create a GitHub OAuth App: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Random 32-char string for session encryption (required)
# Generate with: openssl rand -hex 16
BETTER_AUTH_SECRET=generate_a_32_char_random_string

# Base URL of the app (required)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Database (required)
# ──────────────────────────────────────────────
# SQLite file path (default: prisma/dev.db)
DATABASE_URL=file:./prisma/dev.db

# ──────────────────────────────────────────────
# GitHub API (local-hub proxy)
# ──────────────────────────────────────────────
# Set to local-hub address to route all GitHub API calls through the proxy
GITHUB_API_URL=http://localhost:8787
# GITHUB_GRAPHQL_URL defaults to ${GITHUB_API_URL}/graphql
# GITHUB_GRAPHQL_URL=http://localhost:8787/graphql

# ──────────────────────────────────────────────
# Redis (required)
# ──────────────────────────────────────────────
# Upstash Redis REST API for caching GitHub API data
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=local_token

# ──────────────────────────────────────────────
# AI — Ghost assistant (optional)
# ──────────────────────────────────────────────
# OpenRouter API key — powers Ghost AI assistant (optional with CLI providers)
# OPEN_ROUTER_API_KEY=your_open_router_api_key

# Model IDs (optional — defaults shown)
# GHOST_MODEL=moonshotai/kimi-k2.5
# GHOST_MERGE_MODEL=google/gemini-2.5-pro-preview

# Anthropic API key — used for specific AI tasks
# ANTHROPIC_API_KEY=your_anthropic_api_key

# CLI AI providers (auto-detected if installed locally):
# - Claude Code: claude-code:claude-sonnet-4-6
# - Gemini CLI: gemini-cli:gemini-2.5-pro
# - Codex CLI: codex-cli:codex

# ──────────────────────────────────────────────
# E2B — code sandbox (optional)
# ──────────────────────────────────────────────
# E2B_API_KEY=your_e2b_api_key

# ──────────────────────────────────────────────
# Search & Memory (optional)
# ──────────────────────────────────────────────
# MIXEDBREAD_API_KEY=your_mixedbread_api_key
# SUPER_MEMORY_API_KEY=your_super_memory_api_key
