#!/usr/bin/env node

const { execFileSync } = require('child_process')
const path = require('path')
const os = require('os')

const PLATFORMS = {
  'darwin-arm64': '@pleaseai/local-hub-darwin-arm64',
  'darwin-x64': '@pleaseai/local-hub-darwin-x64',
  'linux-arm64': '@pleaseai/local-hub-linux-arm64',
  'linux-x64': '@pleaseai/local-hub-linux-x64',
}

function getBinaryPath() {
  const platform = os.platform()
  const arch = os.arch() === 'arm64' ? 'arm64' : 'x64'
  const key = `${platform}-${arch}`
  const pkg = PLATFORMS[key]

  if (!pkg) {
    throw new Error(`Unsupported platform: ${key}`)
  }

  try {
    return path.join(require.resolve(`${pkg}/package.json`), '..', 'bin', 'local-hub')
  }
  catch {
    throw new Error(
      `Could not find binary package ${pkg}. ` +
      `Make sure optional dependencies are installed.`,
    )
  }
}

try {
  const binary = getBinaryPath()
  execFileSync(binary, process.argv.slice(2), { stdio: 'inherit' })
}
catch (err) {
  if (err.status !== undefined) {
    process.exit(err.status)
  }
  console.error(err.message)
  process.exit(1)
}
